    "---\n",
    "## 🧹 Step 3: Process\n",
    "\n",
    "In this step we will:\n",
    "- Check for missing values\n",
    "- Check for duplicate rows\n",
    "- Verify data types\n",
    "- Add useful new columns\n",
    "- Clean column names\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8fc292f5",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Check for missing values ──────────────────────────────────────────────────\n",
    "print(\"=== Missing Values ===\")\n",
    "missing = df.isnull().sum()\n",
    "print(missing[missing > 0] if missing.sum() > 0 else \"✅ No missing values found!\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "478cbb1a",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Check for duplicate rows ──────────────────────────────────────────────────\n",
    "duplicates = df.duplicated().sum()\n",
    "print(f\"=== Duplicate Rows ===\")\n",
    "print(f\"{'✅ No duplicates found!' if duplicates == 0 else f'⚠️ {duplicates} duplicate rows found.'}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8ea90798",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Clean column names (remove spaces, lowercase) ─────────────────────────────\n",
    "df.columns = df.columns.str.strip().str.lower().str.replace(' ', '_').str.replace('(', '').str.replace(')', '')\n",
    "\n",
    "print(\"=== Cleaned Column Names ===\")\n",
    "print(df.columns.tolist())\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "b981bd9c",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Map Experience Level to readable labels ───────────────────────────────────\n",
    "experience_map = {1: 'Beginner', 2: 'Intermediate', 3: 'Expert'}\n",
    "df['experience_label'] = df['experience_level'].map(experience_map)\n",
    "\n",
    "# ── Add BMI Category column ────────────────────────────────────────────────────\n",
    "def bmi_category(bmi):\n",
    "    if bmi < 18.5:\n",
    "        return 'Underweight'\n",
    "    elif bmi < 25:\n",
    "        return 'Normal'\n",
    "    elif bmi < 30:\n",
    "        return 'Overweight'\n",
    "    else:\n",
    "        return 'Obese'\n",
    "\n",
    "df['bmi_category'] = df['bmi'].apply(bmi_category)\n",
    "\n",
    "# ── Add Calories per Hour column ──────────────────────────────────────────────\n",
    "df['calories_per_hour'] = (df['calories_burned'] / df['session_durationhours']).round(1)\n",
    "\n",
    "print(\"✅ New columns added: experience_label, bmi_category, calories_per_hour\")\n",
    "df[['experience_level', 'experience_label', 'bmi', 'bmi_category', 'calories_per_hour']].head()\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8cc2dac1",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Final check on cleaned dataset ────────────────────────────────────────────\n",
    "print(f\"✅ Clean dataset ready: {df.shape[0]} rows × {df.shape[1]} columns\")\n",
    "df.head()\n"
   ]
  },
