    "# Then place the CSV in the same folder as this notebook\n",
    "\n",
    "df = pd.read_csv('gym_members_exercise_tracking.csv')\n",
    "\n",
    "print(\"✅ Dataset loaded successfully!\")\n",
    "print(f\"Shape: {df.shape[0]} rows × {df.shape[1]} columns\")\n"
   ]
